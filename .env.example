# ---------------------------------------------------------------------------
# demand-drafting-ui environment
# Copy this file to `.env` and fill in the blanks. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Filevine — copy real values from:
#   C:\Users\Henry Knotts\Desktop\Client Relations\Admin\config.ps1
# (PowerShell vars $FV_PAT, $FV_CLIENT_ID, $FV_CLIENT_SECRET, $FV_ORG_ID,
#  $FV_USER_ID map 1:1 to the names below)
FV_PAT=
FV_CLIENT_ID=
FV_CLIENT_SECRET=
FV_ORG_ID=6907
FV_USER_ID=90868
FV_API_BASE=https://api.filevineapp.com
FV_PROJ_TYPE_ID=20164

# Anthropic
# ⚠️ WARNING: Use ONLY the new, dedicated Anthropic API key Henry provides for
# this project. Do NOT reuse any key found in Admin\config.ps1, in chase-ui, or
# anywhere else on this machine — those predate the Anthropic BAA and are NOT
# HIPAA-eligible. Pointing this app at a non-BAA key with real PHI is a HIPAA
# incident. The server refuses to start if this is empty (see server.js).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# App auth (single shared credential — a floor, not a ceiling; see README)
APP_USERNAME=
APP_PASSWORD=
SESSION_SECRET=

# Optional — local port (Railway injects its own PORT in production)
PORT=3100

# ---------------------------------------------------------------------------
# Inbox monitoring agent (litigation deadlines / servings / demand follow-ups)
# ---------------------------------------------------------------------------
# The agent is DORMANT unless MONITOR_ENABLED=true. Dormant = no timer, endpoints
# return 409, zero Graph token requests. Go live by flipping these env vars and
# restarting — no code change. Recommended rollout:
#   1) deploy with MONITOR_ENABLED unset; confirm [monitor] DISABLED in logs and
#      GET /api/monitor/status shows enabled:false with all counters 0.
#   2) MONITOR_DRY_RUN=true + MONITOR_ENABLED=true — exercises Graph reads only;
#      no email bodies sent to Claude, no Teams/email sent.
#   3) BAA_SIGNED=true, drop MONITOR_DRY_RUN; start LIT_ATTORNEY_EMAILS with ONE
#      canary mailbox, then expand to all three.
MONITOR_ENABLED=
# Independent gate: email BODIES (PHI) are sent to Claude ONLY when this is true.
BAA_SIGNED=
# Runs the pipeline but skips Claude-on-bodies and all Teams/email sends.
MONITOR_DRY_RUN=

# Microsoft Graph — reuse the existing "Chase list bot" app registration. Copy
# real values from Admin\config.ps1 ($MS_CLIENT_ID / $MS_TENANT_ID / $MS_CLIENT_SECRET).
# App (application) permissions required + admin-consented: Mail.Read, Mail.Send.
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=

# Litigation attorney mailboxes to scan (comma-separated).
LIT_ATTORNEY_EMAILS=jesse@melawyers.com,hellay@melawyers.com,eben@melawyers.com
# Mailbox that urgent alerts + the daily digest are sent FROM (needs Mail.Send for
# this address). Alerts/digests are emailed DIRECTLY to each individual attorney.
MONITOR_SENDER=

# Optional tuning
MONITOR_LOOKBACK_DAYS=45
MONITOR_DEADLINE_WARN_DAYS=3
MONITOR_DEMAND_OVERDUE_DAYS=14
MONITOR_DIGEST_HOUR=8
# MONITOR_INTERNAL_DOMAIN defaults to the domain of the first attorney email.
MONITOR_INTERNAL_DOMAIN=
# PHI-FREE state file (ids/dates/enums only — never PHI). Defaults to ./agent-state.json
MONITOR_STATE_FILE=
