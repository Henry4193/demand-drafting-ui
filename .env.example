# ---------------------------------------------------------------------------
# demand-drafting-ui environment
# Copy this file to `.env` and fill in the blanks. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Filevine — copy real values from:
#   C:\Users\Henry Knotts\Desktop\Client Relations\Admin\config.ps1
# (PowerShell vars $FV_PAT, $FV_CLIENT_ID, $FV_CLIENT_SECRET, $FV_ORG_ID,
#  $FV_USER_ID map 1:1 to the names below)
FV_PAT=
FV_CLIENT_ID=
FV_CLIENT_SECRET=
FV_ORG_ID=6907
FV_USER_ID=90868
FV_API_BASE=https://api.filevineapp.com
FV_PROJ_TYPE_ID=20164

# Anthropic
# ⚠️ WARNING: Use ONLY the new, dedicated Anthropic API key Henry provides for
# this project. Do NOT reuse any key found in Admin\config.ps1, in chase-ui, or
# anywhere else on this machine — those predate the Anthropic BAA and are NOT
# HIPAA-eligible. Pointing this app at a non-BAA key with real PHI is a HIPAA
# incident. The server refuses to start if this is empty (see server.js).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# App auth (single shared credential — a floor, not a ceiling; see README)
APP_USERNAME=
APP_PASSWORD=
SESSION_SECRET=

# Optional — local port (Railway injects its own PORT in production)
PORT=3100
